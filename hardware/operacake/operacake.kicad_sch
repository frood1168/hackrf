	(text "RF ports are arranged on two sides of the board, the A side\n(PA0 - PA4) and the B side (PB0 - PB4).  The \"zero\" ports (PA0\nand PB0) are always each connected to one other port but\nnever to each other.  When PA0 is connected to an A side port,\nPB0 must be connected to a B side port.  When PA0 is connected\nto a B side port, PB0 must be connected to an A side port."
		(exclude_from_sim no)
		(at 113.03 25.4 0)
		(effects
			(font
				(size 1.016 1.016)
			)
			(justify left bottom)
		)
		(uuid "013d14a7-c5cd-4725-9326-801929dad55a")
	)
	(text "high"
		(exclude_from_sim no)
		(at 313.69 226.06 0)
		(effects
			(font
				(size 1.016 1.016)
			)
			(justify left bottom)
		)
		(uuid "0917e4a3-e35b-4411-81c6-41179bc6f6bd")
	)
	(text "Default I2C address is 0x30/0x31.\nUse jumpers to change address\nup to 0x3E/0x3F."
